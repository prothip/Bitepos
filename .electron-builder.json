{
  "appId": "com.bitepos.pos",
  "productName": "BitePOS POS",
  "copyright": "Copyright 2024 BitePOS",
  "directories": {
    "output": "dist-electron",
    "buildResources": "public"
  },
  "files": [
    "package.json",
    "electron/**/*",
    ".next/standalone/**/*",
    ".next/static/**/*",
    "public/**/*",
    "node_modules/**/*",
    "!node_modules/electron/**",
    "!node_modules/electron-builder/**"
  ],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": "nextjs-standalone",
      "filter": ["**/*"]
    },
    {
      "from": ".next/static",
      "to": "nextjs-standalone/.next/static",
      "filter": ["**/*"]
    },
    {
      "from": "dev.db",
      "to": "nextjs-standalone/dev.db"
    },
    {
      "from": "prisma",
      "to": "nextjs-standalone/prisma",
      "filter": ["**/*"]
    },
    {
      "from": "public",
      "to": "nextjs-standalone/public",
      "filter": ["**/*"]
    }
  ],
  "publish": {
    "provider": "generic",
    "url": "https://updates.bitepos.com"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "public/icon.png",
    "category": "public.app-category.business"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png",
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "differentialPackage": true
  }
}