{
  "appId": "com.bitepos.pos",
  "productName": "BitePOS POS",
  "copyright": "Copyright 2024 BitePOS",
  "directories": {
    "output": "dist-electron",
    "buildResources": "public"
  },
  "files": [
    "package.json",
    "electron/**/*",
    ".next/standalone/**/*",
    ".next/static/**/*",
    "public/**/*",
    "prisma/**/*",
    "dev.db",
    "node_modules/**/*",
    "!node_modules/electron/**",
    "!node_modules/electron-builder/**",
    "!node_modules/@electric-sql/**"
  ],
  "asarUnpack": [
    ".next/standalone/**/*",
    "node_modules/better-sqlite3/**/*",
    "node_modules/@prisma/**/*",
    "node_modules/.prisma/**/*",
    "node_modules/@libsql/**/*"
  ],
  "extraResources": [
    {
      "from": "public/fonts/",
      "to": "fonts/"
    }
  ],
  "publish": {
    "provider": "generic",
    "url": "https://updates.bitepos.com"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "public/icon.png",
    "category": "public.app-category.business"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png",
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "differentialPackage": true
  }
}