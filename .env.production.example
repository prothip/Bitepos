# Production Environment Variables
# Copy this to .env.production and fill in real values

# JWT Secret — MUST be changed! Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-here

# License Server URL (your BitePOS Cloud instance)
NEXT_PUBLIC_LICENSE_SERVER=https://cloud.bitepos.com

# App URL (for callbacks)
NEXT_PUBLIC_APP_URL=https://app.bitepos.com